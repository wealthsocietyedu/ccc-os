# ─── Content Command Center OS — Server Config ───────────────────────────────
# Copy this to .env and fill in your values. Never commit .env to git.

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-in-production
DB_PATH=./data/ccc_os.db
CLIENT_URL=http://localhost:5173

# ─── STRIPE ──────────────────────────────────────────────────────────────────
# dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# dashboard.stripe.com/products — create 6 prices, paste IDs below
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_OPERATOR_MONTHLY_PRICE_ID=price_...
STRIPE_OPERATOR_ANNUAL_PRICE_ID=price_...

# ─── PAYPAL ───────────────────────────────────────────────────────────────────
# developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_ENV=sandbox
# developer.paypal.com/dashboard/subscriptions — create 6 plans
PAYPAL_STARTER_MONTHLY_PLAN_ID=P-...
PAYPAL_STARTER_ANNUAL_PLAN_ID=P-...
PAYPAL_PRO_MONTHLY_PLAN_ID=P-...
PAYPAL_PRO_ANNUAL_PLAN_ID=P-...
PAYPAL_OPERATOR_MONTHLY_PLAN_ID=P-...
PAYPAL_OPERATOR_ANNUAL_PLAN_ID=P-...

# ─── AI PROVIDERS (add when building AI Studio) ───────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ELEVENLABS_API_KEY=xi_...
# RUNWAY_API_KEY=...
# FAL_API_KEY=...

# ─── SCHEDULER — PLATFORM OAUTH ───────────────────────────────────────────────
# YouTube (Google Cloud Console → OAuth 2.0)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Instagram & Facebook (Meta Developer App)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn (LinkedIn Developer Portal)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── ADMIN ACCESS ─────────────────────────────────────────────────────────────
# Email that auto-gets admin on registration (your email)
ADMIN_EMAIL=you@youremail.com

# Secret header for the /api/auth/make-admin endpoint
ADMIN_SECRET=change-this-to-something-long-and-random

# Set to 'true' to bypass ALL billing checks for ALL users (dev/testing only)
# Remove or set to 'false' before going live
BYPASS_BILLING=false
